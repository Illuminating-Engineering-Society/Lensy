{
  "name": "lucius",
  "version": "0.1.0",
  "description": "IES AI-Powered Standards Search Assistant",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate:remote": "wrangler d1 migrations apply ies-metadata --remote",
    "db:migrate:local": "wrangler d1 migrations apply ies-metadata --local",
    "ingest": "node scripts/ingest-pdfs.js --dir pdfs/",
    "ingest:deprecated": "node scripts/ingest-pdfs.js --dir \"pdfs/Deprecated Standards\"",
    "ingest:apps": "node scripts/ingest-pdfs.js --applications-only",
    "rename:deprecated": "node scripts/rename-deprecated.js",
    "extract": "node scripts/extract-applications-from-pdf.js",
    "sync-metadata": "node scripts/sync-metadata.js",
    "test:search": "node scripts/test-search.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "cf-typegen": "wrangler types",
    "typecheck": "tsc --noEmit -p tsconfig.worker.json && tsc --noEmit -p tsconfig.scripts.json"
  },
  "dependencies": {
    "pdfjs-dist": "^4.9.155"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.5.0",
    "@cloudflare/workers-types": "^4.20260702.1",
    "@types/node": "^20.19.43",
    "typescript": "^5.9.3",
    "vitest": "^2.1.0",
    "wrangler": "^3.100.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
