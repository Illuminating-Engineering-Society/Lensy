  "application_columns": {
    "_comment": "The 68 columns from the legacy Illuminance Selector database",
    "identity": ["id", "code", "App", "App_s1", "App_s2", "App_s3", "App_s4", "App_s5", "App_s6"],
    "standard_reference": ["Standard", "Standard_Full", "Table_Ref", "Row_Ref", "Link_Mapping"],
