    "notes": ["Footnotes", "General_Notes", "App_Notes"],
    "vitrium": ["Vitrium_Doc_ID", "Vitrium_Deep_Link"],
    "status": ["Active", "Deprecated_By"]
  },
  "illuminance_categories": {
    "_comment": "IES illuminance category definitions A through P",
    "A": { "range_lux": "20-30", "description": "Public spaces with dark surroundings" },
    "B": { "range_lux": "50", "description": "Simple orientation for short visits" },
    "C": { "range_lux": "100", "description": "Working spaces where visual tasks only occasionally performed" },
    "D": { "range_lux": "200", "description": "Performance of visual tasks of high contrast or large size" },
    "E": { "range_lux": "500", "description": "Performance of visual tasks of medium contrast or small size" },
    "F": { "range_lux": "1000", "description": "Performance of visual tasks of low contrast or very small size" },
    "G": { "range_lux": "2000-3000", "description": "Performance of visual tasks near threshold" },
    "H": { "range_lux": "5000-7500", "description": "Performance of very prolonged and exacting visual tasks" },
    "I": { "range_lux": "10000+", "description": "Performance of very special visual tasks" },
    "J": { "range_lux": "30", "description": "Outdoor, non-task areas" },
    "K": { "range_lux": "50", "description": "Outdoor pedestrian areas" },
    "L": { "range_lux": "75", "description": "Outdoor working areas" },
    "M": { "range_lux": "200", "description": "Outdoor task areas (general)" },
    "N": { "range_lux": "300", "description": "Outdoor task areas (detailed)" },
    "O": { "range_lux": "500", "description": "Outdoor precision tasks" },
    "P": { "range_lux": "1000", "description": "Outdoor high-precision tasks" }
  }
}
